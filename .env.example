# Server
HTTP_ADDR=:8080
DATABASE_URL=postgres://creatives:creatives@localhost:5432/creatives?sslmode=disable
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Auth
AUTH_JWT_SECRET=change-me

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Migrations
MIGRATIONS_DIR=./migrations
SKIP_SQL_MIGRATIONS=0

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=creatives
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_USE_PATH_STYLE=1

# LLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_DEFAULT_PROVIDER=openai

# Research
SERPER_API_KEY=
JINA_READER_ENABLED=1

# Audio (fixed)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Video (default provider — override per run in UI)
VIDEO_PROVIDER_DEFAULT=kling
KLING_API_KEY=
RUNWAY_API_KEY=
LUMA_API_KEY=
GOOGLE_VEO_API_KEY=

# Image
IDEOGRAM_API_KEY=
RECRAFT_API_KEY=

# Subtitles
DEEPGRAM_API_KEY=

# Supervisor
SUPERVISOR_MIN_SCORE=75

# Workers
WORKER_LLM_CONCURRENCY=30
WORKER_MEDIA_CONCURRENCY=10
WORKER_VIDEO_CONCURRENCY=3
WORKER_RENDER_CONCURRENCY=2
WORKER_HEARTBEAT_INTERVAL_SEC=30
WORKER_STALE_THRESHOLD_MIN=30

# Storage
STORAGE_DIR=./storage
RENDER_DIR=../worker-render

# Video AI
VIDEO_MOCK=1
VIDEO_MAX_SCENES=3
VIDEO_POLL_INTERVAL_SEC=5
VIDEO_MAX_POLL_MIN=15

# Mock modes (dev/test without external APIs)
LLM_MOCK=1
SERPER_MOCK=1
ELEVENLABS_MOCK=1
RENDER_MOCK=1
